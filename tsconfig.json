{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext", // BU QATOR MUHIM: 'es2015' yoki undan yuqori bo'lishi shart
    "moduleResolution": "bundler", // Endi 'bundler' xatosiz ishlaydi
    
    "jsx": "react-jsx", // Oldingi JSX xatolarini ham yo'qotadi
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "strict": true,
    "skipLibCheck": true,
    "types": ["vite-plugin-pwa/client"]
  }
}